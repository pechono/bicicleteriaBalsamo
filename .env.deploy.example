# Credenciales SSH de Hostinger
# Copiá este archivo como .env.deploy y completá tus datos

# Hostinger: hPanel → Avanzado → Acceso SSH
DEPLOY_HOST=srv123456789.hostinger.com
DEPLOY_PORT=22
DEPLOY_USER=u123456789
DEPLOY_PASS=tu_password_de_hostinger

# Rutas absolutas en el servidor
# Para saber cuáles son: en Hostinger → Administrador de archivos → abrí una carpeta → mirá la barra de dirección
DEPLOY_APP_PATH=/home/u123456789/bicicleteriaBalsamo
DEPLOY_PUBLIC_PATH=/home/u123456789/public_html
